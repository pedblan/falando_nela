{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "processed/textos_parlamentares/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "texto_id",
    "dataset_version",
    "source",
    "dataset",
    "casa",
    "ambito",
    "documento_tipo",
    "unidade_analitica",
    "data",
    "ano",
    "mes",
    "texto",
    "texto_tamanho",
    "raw_run_id",
    "raw_source_id",
    "raw_path"
  ],
  "properties": {
    "texto_id": {"type": "string", "description": "Identificador estavel da unidade textual normalizada."},
    "dataset_version": {"const": "v1"},
    "source": {"type": ["string", "null"], "description": "Portal/fonte de coleta: senado ou camara."},
    "dataset": {"type": ["string", "null"], "description": "Dataset bruto de origem."},
    "casa": {"type": ["string", "null"], "description": "Casa parlamentar normalizada."},
    "ambito": {"type": ["string", "null"], "description": "Ambito institucional: plenario, congresso, ccj, ccjc, comissao_especial ou indeterminado."},
    "orgao_sigla": {"type": ["string", "null"]},
    "orgao_nome": {"type": ["string", "null"]},
    "documento_tipo": {"type": ["string", "null"], "description": "Tipo textual comum: discurso, notas_taquigraficas ou parecer_pec."},
    "unidade_analitica": {"type": ["string", "null"], "description": "Granularidade textual: pronunciamento, discurso, reuniao, evento ou parecer."},
    "data": {"type": ["string", "null"], "description": "Data ISO AAAA-MM-DD escolhida para analise temporal."},
    "data_hora": {"type": ["string", "null"], "description": "Data/hora original quando disponivel."},
    "ano": {"type": ["string", "null"]},
    "mes": {"type": ["string", "null"]},
    "titulo": {"type": ["string", "null"]},
    "resumo": {"type": ["string", "null"]},
    "indexacao": {"type": ["string", "null"]},
    "tipo_discurso": {"type": ["string", "null"]},
    "tipo_uso_palavra": {"type": ["string", "null"]},
    "fase_evento": {"type": ["string", "null"]},
    "parlamentar_id": {"type": ["string", "null"]},
    "parlamentar_nome": {"type": ["string", "null"]},
    "parlamentar_partido": {"type": ["string", "null"]},
    "parlamentar_uf": {"type": ["string", "null"]},
    "parlamentar_cargo": {"type": ["string", "null"]},
    "pronunciamento_id": {"type": ["string", "null"]},
    "sessao_id": {"type": ["string", "null"]},
    "reuniao_id": {"type": ["string", "null"]},
    "evento_id": {"type": ["string", "null"]},
    "proposicao_id": {"type": ["string", "null"]},
    "materia_id": {"type": ["string", "null"]},
    "documento_id": {"type": ["string", "null"]},
    "proposicao_sigla": {"type": ["string", "null"]},
    "proposicao_numero": {"type": ["string", "null"]},
    "proposicao_ano": {"type": ["string", "null"]},
    "proposicao_identificacao": {"type": ["string", "null"]},
    "documento_classe": {"type": ["string", "null"]},
    "status_deliberativo": {"type": ["string", "null"]},
    "vencido": {"type": ["boolean", "null"]},
    "texto": {"type": ["string", "null"]},
    "texto_tamanho": {"type": "integer"},
    "texto_status": {"type": ["string", "null"]},
    "forma": {"type": ["string", "null"]},
    "metodo_obtencao": {"type": ["string", "null"]},
    "url_texto": {"type": ["string", "null"]},
    "url_audio": {"type": ["string", "null"]},
    "url_video": {"type": ["string", "null"]},
    "url_origem": {"type": ["string", "null"]},
    "fontes": {"type": ["object", "null"], "description": "URLs oficiais preservadas em estrutura nativa."},
    "raw_run_id": {"type": ["string", "null"]},
    "raw_record_type": {"type": ["string", "null"]},
    "raw_source_id": {"type": ["string", "null"]},
    "raw_partition": {"type": ["string", "null"]},
    "raw_collected_at": {"type": ["string", "null"]},
    "raw_checksum": {"type": ["string", "null"]},
    "raw_path": {"type": ["string", "null"]},
    "raw_response_url": {"type": ["string", "null"]}
  }
}

